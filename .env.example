NODE_ENV=development
PORT=5000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=coopsave
DB_CONNECTION_LIMIT=10

# Railway usually provides one of these. If set, it can replace DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME.
DATABASE_URL=
MYSQL_URL=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=
NOMBA_TIMEOUT_MS=30000
NOMBA_AUTH_PATH=/auth/token/issue
NOMBA_VIRTUAL_ACCOUNTS_PATH=/virtual-accounts
NOMBA_TRANSACTIONS_PATH=/transactions
NOMBA_WEBHOOK_SIGNATURE_HEADER=nomba-signature
NOMBA_WEBHOOK_SIGNATURE_ALGORITHM=sha256
